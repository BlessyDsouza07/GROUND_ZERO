# Ground Zero — Engine 1 Environment Variables
# Copy this file to .env and fill in your values.
#
# HOW TO USE:
#   cp .env.example .env
#   (edit .env with your keys)
#
# Engine 1 works with ZERO keys — OSM, Wikidata, Wikipedia are all free & keyless.
# Optional keys unlock additional data sources.

# ──────────────────────────────────────────────────────────
# OPTIONAL: OpenTripMap (free tier — 5000 calls/day)
#   Register at: https://opentripmap.io
#   Adds: tourist importance ratings, extra POI descriptions
# ──────────────────────────────────────────────────────────
OPENTRIPMAP_KEY=

# ──────────────────────────────────────────────────────────
# OPTIONAL: Google Maps (for real-time traffic in later engines)
#   Engine 1 does NOT need this — it's for Engine 3 crowd detection
# ──────────────────────────────────────────────────────────
GOOGLE_MAPS_KEY=

# ──────────────────────────────────────────────────────────
# OPTIONAL: Ticketmaster / Eventbrite (for events — Engine 1 uses RSS only)
#   These are NOT needed for Engine 1 at all.
# ──────────────────────────────────────────────────────────
TICKETMASTER_API_KEY=
EVENTBRITE_API_TOKEN=

# ──────────────────────────────────────────────────────────
# DEBUG MODE (set to true to see verbose output)
# ──────────────────────────────────────────────────────────
DEBUG_MODE=false
